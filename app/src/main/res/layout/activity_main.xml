<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F4FF">

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Имя"
        android:textSize="16sp"
        android:padding="10dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Email"
        android:textSize="16sp"
        android:padding="10dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Возраст"
        android:inputType="number"
        android:textSize="16sp"
        android:padding="10dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Телефон"
        android:inputType="number"
        android:textSize="16sp"
        android:padding="10dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ID записи (для обновления/удаления)"
        android:inputType="number"
        android:textSize="16sp"
        android:padding="10dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Добавить"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnRead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Показать все (в логах)"
        android:backgroundTint="#ffe600"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnUpd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Обновить по ID"
        android:backgroundTint="#FF9800"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnDel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Удалить по ID"
        android:backgroundTint="#F44336"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnClear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Очистить всю таблицу"
        android:backgroundTint="#9C27B0"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnShowAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Открыть все записи"
        android:backgroundTint="#009688"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Результат появится здесь"
        android:textSize="15sp"
        android:padding="10dp"
        android:background="#FFFFFF"
        android:textColor="#333333"/>

</LinearLayout>